# Copy this file to .env.local and fill in your values.

# ===== Database =====
MONGODB_URI=

# ===== Cloudinary =====
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=

# ===== Bootstrap SMTP (admin can override via settings) =====
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM_EMAIL=

# ===== Admin / Auth =====
ADMIN_EMAIL=
ADMIN_PASSWORD=
JWT_SECRET=

NEXT_PUBLIC_SITE_URL=http://localhost:3000
